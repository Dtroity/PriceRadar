# Yandex Foundation Models (embeddings + YandexGPT). Без ключей — Levenshtein, линейный прогноз, rule-based рекомендации.
# Документация: https://yandex.cloud/ru/docs/foundation-models/
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Notifications (optional — без SMTP/VAPID каналы тихо пропускаются)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

VK_NOTIFY_TOKEN=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
