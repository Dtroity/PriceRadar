{
  "name": "@priceradar/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "migrate:latest": "node ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.cjs",
    "migrate:rollback": "node ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.cjs",
    "migrate:make": "node ./node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.cjs",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:procureai": "tsx src/db/migrate-procureai.ts",
    "db:migrate:phase32": "tsx src/db/migrate-phase32.ts",
    "db:migrate:phase34": "tsx src/db/migrate-phase34.ts",
    "db:seed": "tsx src/db/seed.ts",
    "import:azbot": "tsx scripts/importAzbot.ts",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.unit.cjs --runInBand",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.cjs --runInBand",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.3",
    "@sentry/node": "^10.45.0",
    "@sentry/profiling-node": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fuse.js": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "node-telegram-bot-api": "^0.64.0",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pino": "^9.14.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.33.2",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
