# Database
DATABASE_URL=postgresql://priceradar:priceradar@localhost:5432/priceradar

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# Uploads
UPLOAD_DIR=./uploads

# Seed admin (for first run)
ADMIN_EMAIL=admin@priceradar.local
ADMIN_PASSWORD=admin123

# Proviator / multi-tenant
APP_NAME=Proviator
MULTI_TENANT=false
AI_SERVICE_URL=http://localhost:8000
