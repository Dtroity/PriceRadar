# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh

# Google Cloud Vision (invoice OCR in backend worker)
# Host: path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./keys/google.json
# Docker: compose sets GOOGLE_APPLICATION_CREDENTIALS=/app/keys/google.json via volume ./keys:/app/keys

# Structured invoice parse after OCR (existing backend ai/client: OpenAI or Ollama)
OPENAI_API_KEY=
# AI_MODEL=gpt-4o-mini
OLLAMA_URL=http://localhost:11434

LOG_LEVEL=info

# Sentry (optional — omit to disable)
SENTRY_DSN=

# Frontend (Vite): copy to frontend/.env.local when needed
# VITE_SENTRY_DSN=

# Grafana (docker compose) admin password
# GRAFANA_ADMIN_PASSWORD=admin
